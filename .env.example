HOST=127.0.0.1
PORT=8080

# Optional. If set, Mattermost must use this value as the OpenAI API key.
PROXY_API_KEY=change-me

# Required. GigaChat credentials for the Basic OAuth header.
GIGACHAT_CREDENTIALS=base64-client-secret-or-auth-key

# Common values: GIGACHAT_API_PERS, GIGACHAT_API_B2B, GIGACHAT_API_CORP.
GIGACHAT_SCOPE=GIGACHAT_API_B2B

GIGACHAT_MODEL=GigaChat
GIGACHAT_TOKEN_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_API_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1

# Disabled by default for stable plain chat pass-through.
# Enable only if you need Mattermost MCP tools/read_file attachment handling.
ENABLE_MATTERMOST_TOOLS=false

# If your host does not trust the required CA chain, prefer setting
# GIGACHAT_CA_BUNDLE to a PEM file instead of disabling verification.
GIGACHAT_VERIFY_SSL=false
# GIGACHAT_CA_BUNDLE=/path/to/russian-trusted-root-ca.pem

REQUEST_TIMEOUT=120
REQUEST_BODY_TIMEOUT=60
REQUEST_BODY_IDLE_TIMEOUT=1
